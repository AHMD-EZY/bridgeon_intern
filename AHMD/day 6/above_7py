import sqlite3

conn = sqlite3.connect("students.db")
cursor = conn.cursor()

cursor.execute(
    "SELECT * FROM students WHERE marks > ?",
    (70,)
)

students = cursor.fetchall()

for student in students:
    print(
        f"ID: {student[0]}, "
        f"Name: {student[1]}, "
        f"Marks: {student[2]}"
    )

conn.close()